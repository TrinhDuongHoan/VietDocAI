APP_NAME=VietDocAI
APP_ENVIRONMENT=development
APP_VERSION=0.2.0
DOCS_ENABLED=true
# Leave empty for local development. Set a strong secret in production.
API_KEY=
HEALTH_BROKER_TIMEOUT_SECONDS=3

POSTGRES_DB=vietdoc
POSTGRES_USER=vietdoc
POSTGRES_PASSWORD=vietdoc_local_password

DATABASE_URL=postgresql+psycopg://vietdoc:vietdoc_local_password@postgres:5432/vietdoc
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

RABBITMQ_USER=vietdoc
RABBITMQ_PASSWORD=vietdoc_rabbit_password

CELERY_BROKER_URL=amqp://vietdoc:vietdoc_rabbit_password@rabbitmq:5672//
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=330

UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=20

OCR_DEVICE=cpu
OCR_CPU_THREADS=4
OCR_LANGUAGE=vi
OCR_VERSION=PP-OCRv6
