APP_NAME=VietDocAI
APP_ENVIRONMENT=production
APP_VERSION=0.2.0
DOCS_ENABLED=false

# Recommended: keep API_KEY empty when the whole app is protected by
# reverse-proxy authentication. If you expose API endpoints to other services,
# set a strong random value and send it as X-API-Key.
API_KEY=
HEALTH_BROKER_TIMEOUT_SECONDS=3

POSTGRES_DB=vietdoc
POSTGRES_USER=vietdoc
POSTGRES_PASSWORD=replace_with_a_long_random_postgres_password

DATABASE_URL=postgresql+psycopg://vietdoc:replace_with_a_long_random_postgres_password@postgres:5432/vietdoc
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

RABBITMQ_DEFAULT_USER=vietdoc
RABBITMQ_DEFAULT_PASS=replace_with_a_long_random_rabbitmq_password
RABBITMQ_USER=vietdoc
RABBITMQ_PASSWORD=replace_with_a_long_random_rabbitmq_password

CELERY_BROKER_URL=amqp://vietdoc:replace_with_a_long_random_rabbitmq_password@rabbitmq:5672//
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=330

UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=20

OCR_DEVICE=cpu
OCR_CPU_THREADS=4
OCR_LANGUAGE=vi
OCR_VERSION=PP-OCRv6
